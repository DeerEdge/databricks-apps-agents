# Medical Desert Planner — environment template
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# Server-only vars stay on the backend (Next.js API routes). Only NEXT_PUBLIC_* reach the browser.

# ── Databricks workspace ───────────────────────────────────────────────
DATABRICKS_HOST=                # e.g. https://dbc-xxxxxxxx.cloud.databricks.com
DATABRICKS_TOKEN=               # personal access token (server-only secret)
DATABRICKS_WAREHOUSE_ID=        # SQL warehouse id (Statement Execution API)

# ── Databricks AI surfaces ─────────────────────────────────────────────
DATABRICKS_GENIE_SPACE_ID=      # Genie space over the gold tables (NL Q&A)
DATABRICKS_AGENT_ENDPOINT=      # Mosaic AI Model Serving endpoint name/URL (agent)
MOSAIC_AI_ENDPOINT=             # e.g. https://<workspace>/serving-endpoints/<endpoint>/invocations

# ── Lakebase (OLTP — persisted planning scenarios) ─────────────────────
# Provision once: POST /api/2.0/database/instances {"name":"meddesert","capacity":"CU_1"}.
# The Postgres password is a short-lived token minted from DATABRICKS_TOKEN at runtime.
LAKEBASE_INSTANCE=              # e.g. meddesert
LAKEBASE_HOST=                 # instance read_write_dns (….database.cloud.databricks.com)
LAKEBASE_USER=                 # your Databricks principal (email / service principal)
LAKEBASE_DATABASE=databricks_postgres

# ── Map (optional) ─────────────────────────────────────────────────────
# Leave blank to use the free CARTO basemap (no token needed).
# Set only if you switch to a custom/Mapbox style.
NEXT_PUBLIC_MAP_STYLE_URL=
NEXT_PUBLIC_MAPBOX_TOKEN=
