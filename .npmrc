# Test tooling (@vitejs/plugin-react -> vite 8) has a strict @types/node peer range that
# conflicts with the @types/node Next.js auto-installs to match the build's Node 20 runtime.
# These are dev-only deps (not used by `next build`), so relax peer resolution to let the
# Databricks Apps build's `npm install` succeed. npm 7+ would otherwise fail with ERESOLVE.
legacy-peer-deps=true
